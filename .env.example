# Comma-separated list of phone numbers (including country code, without '+' or spaces) 
# that are allowed to trigger and test the bot.
# Example: 919934225353,918888888888
ALLOWED_NUMBERS=919934225353

# Your Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Calendar Service Account Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=goran.dotin@gmail.com # The email/ID of the calendar you wish to book events on

# SMTP Mail Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=goran.dotin@gmail.com
SMTP_PASS=your-gmail-app-password
NOTIFICATION_EMAIL=goran.dotin@gmail.com

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/goran-bot
